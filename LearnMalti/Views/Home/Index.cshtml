@{
    Layout = null;
    ViewData["Title"] = "Participation Information";
}

<meta charset="utf-8" />
<title>@ViewData["Title"]</title>
<link rel="stylesheet" href="~/css/index.css" />

<div class="landing-container">

    <div class="landing-box">

        <!-- Progress -->
        <div class="progress">
            <div class="progress-bar" id="progressBar"></div>
        </div>

        <!-- FORM STEP 1 -->
        <div class="form-step active">
            <h2>👋 Hello!</h2>

            <p>
                My name is <b>Clayton Galea</b> and I am making a project
                for my studies at <b>MCAST</b>.
            </p>

            <p>
                I created a computer game to help children learn Maltese words.
            </p>

            <p>
                I would like to ask if you would like to try the game
                and help me with my project.
            </p>
        </div>

        <!-- STEP 2 -->
        <div class="form-step">
            <h2>🖥 What will you do?</h2>

            <p>If you say yes, you will:</p>

            <ul>
                <li>🎮 Play a short learning game</li>
                <li>📚 Answer some Maltese word questions</li>
                <li>🙂 Tell us what you think about the game</li>
            </ul>

            <p>This will take about one school lesson.</p>
        </div>

        <!-- STEP 3 -->
        <div class="form-step">
            <h2>🤔 Do you have to do this?</h2>

            <p>No. It is your choice.</p>

            <p>You can say <b>NO</b> and that is completely okay 👍</p>
        </div>

        <!-- STEP 4 -->
        <div class="form-step">
            <h2>✋ Can you stop later?</h2>

            <p>
                Yes! If you start playing and later do not want to continue,
                you can stop at any time.
            </p>

            <p>Just tell your teacher or me.</p>
        </div>

        <!-- STEP 5 -->
        <div class="form-step">
            <h2>🔒 Will anyone know your answers?</h2>

            <p>
                Your name will not be used.
            </p>

            <p>
                We only look at how the game works for children,
                not how well anyone does.
            </p>
        </div>

        <!-- FINAL STEP -->
        <div class="form-step">

            <h2>😊 Do you want to help?</h2>

            <p class="participant-info">
                Your anonymous Player ID: <span id="playerIdDisplay">Loading...</span>
            </p>

            <p class="participant-info">
                Date: <span id="currentDateDisplay"></span>
            </p>

            <div class="emoji-buttons">

                <div class="emoji-option">
                    <span class="emoji-label">NO</span>
                    <button class="emoji-btn sad" onclick="submitAnswer(false)">🙁</button>
                </div>

                <div class="emoji-option">
                    <span class="emoji-label">YES</span>
                    <button class="emoji-btn happy" onclick="submitAnswer(true)">🙂</button>
                </div>

            </div>

        </div>

        <!-- NEXT BUTTON -->
        <button class="next-btn" id="nextBtn" onclick="nextStep()">Next ➜</button>

    </div>

</div>
<script>

    let playerCode = null;

    document.addEventListener("DOMContentLoaded", async function () {

        try {

            const response = await fetch("/api/playerapi/create", {
                method: "POST"
            });

            const data = await response.json();

            playerCode = data.playerCode;

            sessionStorage.setItem("playerCode", playerCode);

            const idElement = document.getElementById("playerIdDisplay");
            if (idElement) {
                idElement.innerText = playerCode;
            }

            // Display current date
            const dateElement = document.getElementById("currentDateDisplay");

            const today = new Date();

            const formattedDate = today.toLocaleDateString("en-GB", {
                day: "numeric",
                month: "long",
                year: "numeric"
            });

            if (dateElement) {
                dateElement.innerText = formattedDate;
            }

        } catch (err) {
            console.error("Player creation failed", err);
        }

    });

</script>
<script>

    let currentStep = 0;

    const steps = document.querySelectorAll(".form-step");
    const progressBar = document.getElementById("progressBar");
    const nextBtn = document.getElementById("nextBtn");

    function showStep() {

        steps.forEach((step, i) => {
            step.classList.remove("active");
            if (i === currentStep) step.classList.add("active");
        });

        let progress = ((currentStep) / (steps.length - 1)) * 100;
        progressBar.style.width = progress + "%";

        if (currentStep === steps.length - 1) {
            nextBtn.style.display = "none";
        }
    }

    function nextStep() {

        if (currentStep < steps.length - 1) {
            currentStep++;
            showStep();
        }
    }

    function submitAnswer(answer) {

        if (answer) {
            window.location.href = "/Menu/SelectMode";
        } else {
            window.close();
        }
    }

    showStep();

</script>
