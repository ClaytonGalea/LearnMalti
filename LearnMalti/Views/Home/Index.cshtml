@{
    Layout = null;
    ViewData["Title"] = "Welcome Page";
}

<meta charset="utf-8" />
<title>@ViewData["Title"]</title>

<div class="landing-container">

    <div class="landing-box">
        <h1 class="landing-title">Welcome</h1>
        <h1 class="landing-title">Would you like to participate?</h1>

        <div class="emoji-buttons">

            <div class="emoji-option">
                <span class="emoji-label">NO</span>
                <button class="emoji-btn sad" onclick="submitAnswer(false)">
                    🙁
                </button>
            </div>

            <div class="emoji-option">
                <span class="emoji-label">YES</span>
                <button class="emoji-btn happy" onclick="submitAnswer(true)">
                    🙂
                </button>
            </div>

        </div>
    </div>

</div>

<script>
    function submitAnswer(answer) {
        if (answer) {
            window.location.href = "/Menu/SelectMode"; // YES
        } else {
            window.close();
        }
    }
</script>

<style>

    html, body {
        margin: 0;
        padding: 0;
        height: 100%;
        overflow: hidden;
    }

    /* Full-screen background */
    .landing-container {
        height: 100vh;
        width: 100%;
        background: linear-gradient(180deg, #A5D6A7 0%, #C8E6C9 100%);
        display: flex;
        justify-content: center;
        align-items: center;
        font-family: "Comic Sans MS", "Poppins", sans-serif;
        text-align: center;
    }

    /* Main white box */
    .landing-box {
        background: white;
        padding: 60px;
        border-radius: 30px;
        box-shadow: 0 8px 20px rgba(0,0,0,0.15);
        width: 1000px;
        animation: fadeIn 0.8s ease-out;
    }

    .landing-title {
        font-size: 42px;
        margin-bottom: 40px;
    }

    .happy:hover {
        filter: drop-shadow(0 0 15px #4CAF50);
    }

    .sad:hover {
        filter: drop-shadow(0 0 15px #f44336);
    }

    .emoji-buttons {
        display: flex;
        justify-content: center;
        align-items: center;
        gap: 120px; /* space between NO and YES */
        margin-top: 30px;
    }

    .emoji-option {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
    }

    .emoji-label {
        font-size: 20px;
        font-weight: bold;
        margin-bottom: 10px;
    }

    .emoji-btn {
        font-size: 80px;
        background: none;
        border: none;
        cursor: pointer;
        transition: transform 0.2s ease;
    }

        .emoji-btn:hover {
            transform: scale(1.15);
        }

</style>