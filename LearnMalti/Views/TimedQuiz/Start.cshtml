@model LearnMalti.Models.LearningItem

@{
    Layout = "~/Views/Shared/_TimedQuizLayout.cshtml";

    string playerCode = ViewBag.PlayerCode;
    int step = ViewBag.Step;
    int score = ViewBag.Score;
    int mode = ViewBag.Mode;
    int lives = ViewBag.Lives ?? 3;
    int incorrectAnswers = ViewBag.IncorrectAnswers ?? 0;
    int streak = ViewBag.Streak ?? 0;
    int correctAnswers = ViewBag.CorrectAnswers ?? 0;


    var choices = ViewBag.Choices as List<string>;

    ViewBag.HasLives = true;
    ViewBag.Lives = lives;
    ViewBag.Streak = streak;
}

<div class="card">

    <h2 class="quiz-title">@ViewBag.QuestionText</h2>


    @foreach (var c in choices)
    {
        <button class="choice" onclick="submitAnswer('@c')">@c</button>
    }

</div>

<script>
    function normalizeText(text) {
        return text
            .toLowerCase()
            .normalize("NFD")
            .replace(/[\u0300-\u036f]/g, "")
            .trim();
    }

    function submitAnswer(answer) {

        // ✅ SAFE JSON SERIALIZATION
        const correct = @Html.Raw(
            System.Text.Json.JsonSerializer.Serialize(ViewBag.CorrectAnswer)
        );

        let step = @step;
        let score = @score;
        let incorrectAnswers = @incorrectAnswers;
        let streak = @streak;
        let mode = @mode;
        let lives = @lives;
        let playerCode = "@playerCode";
        let correctAnswers = @correctAnswers;

        const isCorrect =
            normalizeText(answer) === normalizeText(correct);

        // ==========================
        // ✅ CORRECT ANSWER
        // ==========================
        if (isCorrect) {

            step++;
            streak++;
            correctAnswers++;

            if (mode === 1) {
                // Base score
                score += 10;

                // Streak bonuses
                if (streak === 3) {
                    score += 30;
                }
                else if (streak === 5) {
                    score += 50;
                }
            }

            Swal.fire({
                title: mode === 1 ? "Correct!": "",
                text:mode === 1 ? `Score: ${score}`: "",
                icon: "success",
                timer: 800,
                showConfirmButton: false
            }).then(() => {

                window.location.href =
                    `/TimedQuiz/Start?playerCode=${playerCode}` +
                    `&step=${step}` +
                    `&score=${score}` +
                    `&correctAnswers=${correctAnswers}` +
                    `&incorrectAnswers=${incorrectAnswers}` +
                    `&streak=${streak}` +
                    `&mode=${mode}` +
                    `&lives=${lives}`;
            });

            return;
        }

        // ==========================
        // ❌ WRONG ANSWER
        // ==========================

        step++;
        incorrectAnswers++;
        streak = 0;

        if (mode === 1) {
            lives--;

            if (lives <= 0) {
                window.location.href =
                    `/TimedQuiz/Completed?playerCode=${playerCode}` +
                    `&mode=${mode}` +
                    `&score=${score}` +
                    `&correctAnswers=${correctAnswers}` +
                    `&incorrectAnswers=${incorrectAnswers}`;
                return;
            }
        }

        Swal.fire({
            title: mode === 1 ? "Wrong!": "",
            text: mode === 1 ? "Score: ${score}": "",
            icon: "error",
            timer: 800,
            showConfirmButton: false
        }).then(() => {

            window.location.href =
                `/TimedQuiz/Start?playerCode=${playerCode}` +
                `&step=${step}` +
                `&score=${score}` +
                `&correctAnswers=${correctAnswers}` +
                `&incorrectAnswers=${incorrectAnswers}` +
                `&streak=${streak}` +
                `&mode=${mode}` +
                `&lives=${lives}`;
        });
    }
</script>