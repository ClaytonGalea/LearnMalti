@model LearnMalti.Models.LearningItem

@{
    Layout = "~/Views/Shared/_TutorialLayout.cshtml";

    var validAnswers = !string.IsNullOrWhiteSpace(Model.MalteseWord_Font)
        ? new List<string> { Model.MalteseWord_Font, Model.MalteseText }
        : new List<string> { Model.MalteseText };
}

<div class="quiz-card">

    <h1 class="english-word hover-word"
        data-translation="@Model.DisplayMalteseWord">
        @Model.EnglishText
    </h1>

    @if (!string.IsNullOrEmpty(Model.ImageUrl))
    {
        <img src="@Model.ImageUrl" class="quiz-image" />
    }

    <div class="choices-container">
        @foreach (var choice in (List<string>)ViewBag.Choices)
        {
            <button class="choice-btn"
                    data-value="@choice"
                    onclick="checkAnswer(this.dataset.value)">
                @choice
            </button>
        }
    </div>

</div>

<script>

    const correctSound = document.getElementById("correctSound");
    const incorrectSound = document.getElementById("incorrectSound");

    function playSound(audio) {
        if (!audio) return;
        audio.currentTime = 0;
        audio.play().catch(() => {});
    }

    function normalize(text) {
        return text
            .toLowerCase()
            .normalize("NFD")
            .replace(/[\u0300-\u036f]/g, "")
            .trim();
    }

    // ✅ Properly serialized valid answers
    const correctAnswers = @Html.Raw(
        System.Text.Json.JsonSerializer.Serialize(validAnswers)
    );

    function checkAnswer(answer) {

        const nextStep = @ViewBag.Step + 1;
        const score = @ViewBag.Score;
        const mode = @ViewBag.Mode;
        const playerCode = "@ViewBag.PlayerCode";

        const normalizedInput = normalize(answer);

        const isCorrect = correctAnswers.some(a =>
            normalize(a) === normalizedInput
        );

        if (isCorrect) {

            playSound(correctSound);

            if (mode === 1) {
                fetch(`/api/playerapi/addxp?playerCode=${playerCode}&amount=20`, {
                    method: "POST"
                });
            }

            Swal.fire({
                title: "Correct!",
                text: mode === 1 ? "+20 XP" : "Good job!",
                icon: "success",
                timer: 1000,
                showConfirmButton: false
            }).then(() => {

                window.location.href =
                    `/Tutorial/Start?playerCode=${playerCode}` +
                    `&step=${nextStep}` +
                    `&score=${score + 1}` +
                    `&mode=${mode}`;
            });

            return;
        }

        playSound(incorrectSound);

        Swal.fire({
            title: "Incorrect!",
            text: "Try again 🙂",
            icon: "info",
            timer: 1200,
            showConfirmButton: false
        });
    }

</script>