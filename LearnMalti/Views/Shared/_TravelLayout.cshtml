@{
    // Set the layout for this view (Contains: HUD, timer and navigation)
    Layout = "~/Views/Shared/_GameLevelLayout.cshtml";


    int step = ViewBag.step ?? 0; //Current question step
    int total = ViewBag.totalSteps ?? 0; //Total number of questions in the level
    int mode = ViewBag.mode ?? 0; //Game mode (1 = gamified, 0 = non-gamified)
}

@section Styles {
    <link rel="stylesheet" href="~/css/travel.css" asp-append-version="true" />
}

<audio id="trainSound" preload="auto"></audio>
<audio id="busSound" preload="auto"></audio>

@if (step > 0 && total > 0)
{
    <div class="level-header">
        <h2 class="level-title">Travel</h2>
        <div class="progress-hud">
            Question @step of @total
        </div>
    </div>
}

@if(mode == 1)
{
    <!--Background Cards-->
    <div class="tutorial-background">
        <div class="flip-card tree" data-sound="/Sounds/TrainSound.mp3">
            <div class="flip-card-inner">
                <div class="flip-card-front">
                    <img src="/images/words/train.png" />
                </div>
                <div class="flip-card-back">
                    <p>Ferrovija 🚂</p>
                </div>
            </div>
        </div>

        <div class="flip-card bird" data-sound="/Sounds/BusSound.mp3">
            <div class="flip-card-inner">
                <div class="flip-card-front">
                    <img src="/images/words/bus.png" />
                </div>
                <div class="flip-card-back">
                    <p>Xarabank</p>
                </div>
            </div>
        </div>
    </div>
 }


<div class="travel-content">
    @RenderBody()
</div>


<script>
    const audio = document.getElementById('trainSound');
    let audioUnlocked = false;

    // 🔓 Unlock audio on first user interaction (NO hardcoded sound)
    document.addEventListener('click', () => {
        if (audioUnlocked) return;

        audio.volume = 0;
        audio.src = "/Sounds/TrainSound.mp3"; // any valid sound just to unlock
        audio.play().then(() => {
            audio.pause();
            audio.currentTime = 0;
            audio.volume = 0.7;
            audioUnlocked = true;
            console.log("🔓 Audio unlocked");
        }).catch(() => {});
    }, { once: true });

    // 🔊 Play sound per card
    document.querySelectorAll('.flip-card').forEach(card => {
        let played = false;

        card.addEventListener('mouseenter', () => {
            if (!audioUnlocked || played) return;

            const soundSrc = card.dataset.sound;
            if (!soundSrc) return;

            audio.src = soundSrc;
            audio.currentTime = 0;
            audio.play().catch(() => {});

            played = true;
        });

        card.addEventListener('mouseleave', () => {
            played = false;
        });
    });
</script>
