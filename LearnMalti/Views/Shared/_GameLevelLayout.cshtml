@{
    string title = ViewBag.Title ?? "Level";
    string playerCode = ViewBag.PlayerCode;
    int mode = ViewBag.Mode;
    int total = ViewBag.TotalSteps ?? 0;
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>@title</title>

    <link rel="stylesheet" href="~/css/game-layout.css" />
    <link rel="stylesheet" href="~/css/completion.css" />
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

</head>

<body>

    <div class="level-container">

        <div class="game-top-bar">

            <div class="hud-left">
                <a class="home-btn"
                   href="/Menu/Game?playerCode=@playerCode&mode=@mode">
                    🏠 Home
                </a>

                @if (ViewBag.HasLives == true)
                {
                    <div class="lives-hud">
                        @for (int i = 0; i < (ViewBag.Lives ?? 0); i++)
                        {
                            <span class="heart">❤️</span>
                        }
                    </div>
                }
            </div>

            @if (mode == 1)
            {
                <div class="timer-hud">
                    ⏱ <span id="timerText"></span>s
                </div>
            }

        </div>

        <div class="content-area">
            @RenderBody()
        </div>

    </div>

    <!-- TIMER SCRIPT -->
    <script>
        function startTimer(seconds, onFinish) {
            let time = seconds;
            const el = document.getElementById("timerText");
            if (!el) return;

            el.innerText = time;

            const interval = setInterval(() => {
                time--;
                el.innerText = time;

                if (time <= 0) {
                    clearInterval(interval);
                    onFinish();
                }
            }, 1000);
        }
    </script>

    @if (mode == 1)
    {
        <script>
            startTimer(30, () => {
                window.location.href =
                    "@Url.Action("Completed", ViewContext.RouteData.Values["controller"].ToString())"
                    + "?playerCode=@playerCode&total=@total&mode=@mode&timeUp=true";
            });
        </script>
    }

    @RenderSection("Scripts", required: false)

</body>
</html>
