@{
    Layout = null;
    ViewData["Title"] = "Select Mode";
}

<meta charset="utf-8" />
<title>@ViewData["Title"]</title>
<link rel="stylesheet" href="~/css/selectMode.css" />

<div class="mode-container">

    <div class="mode-box">

        <h1 class="mode-title">🎓 Select your mode 🎓</h1>
        <p class="mode-subtitle">Pick your level to begin learning Malti!</p>

        <div class="mode-options">

            <!-- YEAR 1 → Gamified -->
            <div class="mode-card">
                <p class="mode-desc">Fun, interactive, game-based learning!</p>
                <br />
                <button class="mode-btn blue" onclick="selectMode(1, this)">🎮 Gamified</button>
            </div>

            <!-- YEAR 2 → Non-Gamified -->
            <div class="mode-card">
                <p class="mode-desc">Straightforward learning without the game features.</p>

                <button class="mode-btn purple" onclick="selectMode(0, this)">📚 Non-Gamified</button>

            </div>

        </div>
    </div>

</div>

<script>
        async function selectMode(mode, btn) {

        btn.disabled = true;
        btn.innerText = "Loading...";

        const playerCode = sessionStorage.getItem("playerCode");

        try {

            await fetch(`/api/playerapi/setmode?playerCode=${playerCode}&mode=${mode}`, {
                method: "POST"
            });

            window.location.href = `/Menu/Game?playerCode=${playerCode}&mode=${mode}`;

        } catch (err) {

            console.error(err);
            btn.disabled = false;
            btn.innerText = (mode === 1) ? "🎮 Gamified" : "📚 Non-Gamified";

        }
    }
</script>