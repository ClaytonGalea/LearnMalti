@{
    Layout = null;
    var player = ViewBag.Player;
    ViewData["Title"] = "Game Hub";
    string playerCode = Context.Request.Query["playerCode"];
    int mode = int.Parse(Context.Request.Query["mode"]); // 0 = non-gamified, 1 = gamified
    var completed = ViewBag.CompletedLevels as List<string> ?? new List<string>();

    @functions {
        public bool IsUnlocked(List<string> completed, string requiredLevel)
        {
            return completed.Contains(requiredLevel);
        }
    }
}

<meta charset="utf-8" />
<title>@ViewData["Title"]</title>
<link rel="stylesheet" href="~/css/game.css" />

<div class="game-container">

    <!-- LEFT SIDEBAR -->
    <div class="sidebar">

        <h2 class="sidebar-title">👤 Player</h2>
        <p class="player-id">ID: @playerCode</p>
        @if (mode == 1)
        {
            <div class="xp-box">
                <h3>⭐ XP</h3>
                <div class="xp-bar">
                    @{
                        int xpForNextLevel = 100; // adjust if you want scaling
                        double percent = ((double)player.CurrentXp / xpForNextLevel) * 100;
                    }
                    <div class="xp-fill" style="width: @percent%;"></div>
                </div>
                <p class="level">Level @player.CurrentLevel</p>
            </div>
            <div class="badges-box">
                <h3>🏆 Badges</h3>

                <div class="badges">
                    @if (ViewBag.Badges != null && ViewBag.Badges.Count > 0)
                    {
                        foreach (var badge in ViewBag.Badges)
                        {
                            <span class="badge-icon" title="@badge.Name">
                                @badge.IconKey
                            </span>
                        }
                    }
                    else
                    {
                        <span class="no-badges">No badges yet</span>
                    }
                </div>
            </div>


            <div class="leaderboard-box">
                <h3>🏅 Leaderboard</h3>
                <div id="leaderboard">
                    <p>Loading...</p>
                </div>
            </div>

        }

    </div>

    <!-- MAIN CONTENT -->
    <div class="main-content">

        <h1 class="main-title">🌈 Your Adventure</h1>

        <div class="section">

            <h2 class="section-title">📘 Tutorial Level</h2>
            <button class="section-btn" onclick="window.location.href='/Tutorial/Start?playerCode=@player.PlayerCode&mode=@mode'">
                Start Tutorial
            </button>

        </div>

        <div class="section">

            <h2 class="section-title">🍎 Vocabulary Levels</h2>

            <div class="level-row">
                <!--<button class="level-btn" onclick="window.location.href='/FoodDrink/Start?playerCode=@player.PlayerCode&mode=@mode'">🥪 Food & Drink</button>-->
                @{
                    bool foodUnlocked = IsUnlocked(completed, "Tutorial");
                }
                <button class="level-btn @(foodUnlocked ? "" : "locked")"
                @(foodUnlocked ? "" : "disabled")
                        onclick="@(foodUnlocked ? $"window.location.href='/FoodDrink/Start?playerCode={player.PlayerCode}&mode={mode}'" : "")">

                    @if (foodUnlocked)
                    {
                        <span>🥪 Food & Drink</span>
                    }
                    else
                    {
                        <span class="lock-icon">🔒</span>
                        <span>Food & Drink</span>
                      //  <small class="lock-text">Complete Tutorial</small>
                    }
                </button>

                @{
                    bool travelUnlocked = IsUnlocked(completed, "FoodDrink");
                }
                <button class="level-btn @(travelUnlocked ? "" : "locked")"
                @(travelUnlocked ? "" : "disabled")
                        onclick="@(travelUnlocked ? $"window.location.href='/Travel/Start?playerCode={player.PlayerCode}&mode={mode}'" : "")">

                    @if (travelUnlocked)
                    {
                        <span>✈ Travel</span>
                    }
                    else
                    {
                        <span class="lock-icon">🔒</span>
                        <span>Travel</span>
                     //   <small class="lock-text">Complete Food & Drink</small>
                    }

                </button>

                @{
                    bool greetingsUnlocked = IsUnlocked(completed, "Travel");
                }
                <button class="level-btn @(greetingsUnlocked ? "" : "locked")"
                @(greetingsUnlocked ? "" : "disabled")
                        onclick="@(greetingsUnlocked ? $"window.location.href='/Greeting/Start?playerCode={player.PlayerCode}&mode={mode}'" : "")">

                    @if (greetingsUnlocked)
                    {
                        <span>👋 Greetings</span>
                    }
                    else
                    {
                        <span class="lock-icon">🔒</span>
                        <span>Greetings</span>
                      //  <small class="lock-text">Complete Travel</small>
                    }

                </button>

                @{
                    bool colorUnlocked = IsUnlocked(completed, "Greetings");
                }
                <button class="level-btn @(colorUnlocked ? "" : "locked")"
                @(colorUnlocked ? "" : "disabled")
                        onclick="@(colorUnlocked ? $"window.location.href='/Color/Start?playerCode={player.PlayerCode}&mode={mode}'" : "")">

                    @if (colorUnlocked)
                    {
                        <span>🎨 Colors</span>
                    }
                    else
                    {
                        <span class="lock-icon">🔒</span>
                        <span>Colors</span>
                    //    <small class="lock-text">Complete Greetings</small>
                    }

                </button>
            </div>

        </div>

        <div class="section">

            <h2 class="section-title">✏ Grammar Levels</h2>

            <div class="level-row">
                @{
                    bool sinPluUnlocked = IsUnlocked(completed, "Color");
                }
                <button class="level-btn @(sinPluUnlocked ? "" : "locked")"
                @(sinPluUnlocked ? "" : "disabled")
                        onclick="@(sinPluUnlocked ? $"window.location.href='/SinPlu/Start?playerCode={player.PlayerCode}&mode={mode}'" : "")">

                    @if (sinPluUnlocked)
                    {
                        <span>Singular-Plural</span>
                    }
                    else
                    {
                        <span class="lock-icon">🔒</span>
                        <span>Singular-Plural</span>
                    }

                </button>
            </div>

        </div>

        <div class="section">

                <h2 class="section-title">🎮 Mini-Games</h2>

                <div class="level-row">
                @{
                    bool miniGamesUnlocked = IsUnlocked(completed, "Tutorial");
                }
                <!-- ⏱ Timed Quiz -->
                <button class="level-btn @(miniGamesUnlocked ? "" : "locked")"
                @(miniGamesUnlocked ? "" : "disabled")
                        onclick="@(miniGamesUnlocked ? $"window.location.href='/TimedQuiz/Start?playerCode={player.PlayerCode}&mode={mode}'" : "")">

                    @if (miniGamesUnlocked)
                    {
                        <span>⏱ Timed Quiz (30s)</span>
                    }
                    else
                    {
                        <span class="lock-icon">🔒</span>
                        <span>Timed Quiz</span>
                    }

                </button>

                <!-- 🏗 Hangman -->
                @if (mode == 1)
                {
                    <button class="level-btn @(miniGamesUnlocked ? "" : "locked")"
                    @(miniGamesUnlocked ? "" : "disabled")
                            onclick="@(miniGamesUnlocked ? $"window.location.href='/Hangman/Start?playerCode={player.PlayerCode}&mode={mode}'" : "")">

                        @if (miniGamesUnlocked)
                        {
                            <span>🏗️ Hangman</span>
                        }
                        else
                        {
                            <span class="lock-icon">🔒</span>
                            <span>Hangman</span>
                        }

                    </button>
                }

                </div>

            </div>
    </div>

</div>

<script>
    async function addXp() {
        const url = `/api/playerapi/addxp?playerCode=@player.PlayerCode&amount=20`;

        const response = await fetch(url, { method: "POST" });
        const result = await response.json();

        console.log("XP updated:", result);

        // Reload to show new XP bar
        location.reload();
     }
        
</script>


<script>
    document.addEventListener("DOMContentLoaded", function () {
        fetch("/api/playerapi/leaderboard")
            .then(res => res.json())
            .then(players => {
                const board = document.getElementById("leaderboard");

                if (players.length === 0) {
                    board.innerHTML = "<p>No players yet.</p>";
                    return;
                }

                let html = "<ol class='leaderboard-list'>";

                players.forEach(p => {
                    html += `
                        <li>
                            <strong>${p.playerCode}</strong>
                            <span>Lvl ${p.currentLevel}</span>
                        </li>`;
                });

                html += "</ol>";

                board.innerHTML = html;
            })
            .catch(err => {
                document.getElementById("leaderboard").innerHTML =
                    "<p>Error loading leaderboard.</p>";
            });
    });
</script>
