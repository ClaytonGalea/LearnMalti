@{
    Layout = "~/Views/Shared/_HangmanLayout.cshtml";

    int lives = ViewBag.Lives;
    int stage = Math.Clamp(6 - lives, 0, 6);


    string[] stages = 
    {
@"
 +---+
 |   |
     |
     |
     |
     |
=======",

@"
 +---+
 |   |
 O   |
     |
     |
     |
=======",

@"
 +---+
 |   |
 O   |
 |   |
     |
     |
=======",

@"
 +---+
 |   |
 O   |
/|   |
     |
     |
=======",

@"
 +---+
 |   |
 O   |
/|\  |
     |
     |
=======",

@"
 +---+
 |   |
 O   |
/|\  |
/    |
     |
=======",

@"
 +---+
 |   |
 O   |
/|\  |
/ \  |
     |
======="
    };
    
}

<div class="hangman-content">

    
    <!-- WORD DISPLAY -->
    <div class="hangman-word">
        @string.Join(" ", ViewBag.HiddenWord.ToString().ToCharArray())
    </div>

    <div class="hangman-drawing">
        <pre> @stages[stage]</pre>
    </div>

    <!-- GUESS INPUT -->
    <form method="post" action="/Hangman/Guess" class="hangman-input">

        <!-- KEEP GAME PARAMETERS -->
        <input type="hidden" name="playerCode" value="@ViewBag.PlayerCode" />
        <input type="hidden" name="step" value="@ViewBag.Step" />
        <input type="hidden" name="mode" value="@ViewBag.Mode" />
        <input type="hidden" name="lives" value="@ViewBag.Lives" />

        <input type="text"
               name="letter"
               maxlength="1"
               required
               class="letter-box"
               autocomplete="off"
               onfocus="this.value=''" />

        <button type="submit" class="guess-btn">
            Guess
        </button>

        

    </form>

    <!-- GUESSED LETTERS -->
    @if (ViewBag.GuessedLetters != null)
    {
        <div class="guessed-letters">
            <div class="guessed-title">
                Guessed letters
            </div>

            <div class="guessed-container">
                @foreach (var l in ViewBag.GuessedLetters.ToString())
                {
                    <span class="letter-tag">@l</span>
                }
            </div>

        </div>
    }

</div>


<script>
        function goHome(){
        window.location.href = "/Menu/Game?playerCode=@ViewBag.PlayerCode&mode=@ViewBag.Mode";
    }

    function playAgain(){
        window.location.href = "/Hangman/Start?playerCode=@ViewBag.PlayerCode&mode=@ViewBag.Mode";
    }
</script>

@if (ViewBag.WordCompleted == true)
{
    <script>

        fetch(`/api/playerapi/addxp?playerCode=@ViewBag.PlayerCode&amount=100`, {
            method: "POST"
        });

        Swal.fire({
            title: "Great job! 🎉",
            text: "+100 XP You guessed the word!",
            icon: "success",
            confirmButtonText: "Play Again",
            cancelButtonText: "Home",
            showCancelButton: true,
            allowOutsideClick: false
        }).then((result) => {

            if (result.isConfirmed) playAgain();
            else goHome();

        });

    </script>
}

@if (ViewBag.GameOver == true)
{
    <script>
        Swal.fire({
            title: "Game Over 💀",
            text: "You ran out of lives!",
            icon: "error",
            confirmButtonText: "Try Again",
            cancelButtonText: "Home",
            showCancelButton: true,
            allowOutsideClick: false
        }).then((result) => {

            if (result.isConfirmed) playAgain();
            else goHome();

        });

    </script>
}