@model LearnMalti.Models.LearningItem

@{
    Layout = "~/Views/Shared/_ColorLayout.cshtml";

    string playerCode = ViewBag.PlayerCode;
    int step = ViewBag.Step;
    int score = ViewBag.Score;
    int mode = ViewBag.Mode;
    int lives = ViewBag.Lives ?? 3;

    string type = ViewBag.QuestionType;
    var choices = ViewBag.Choices as List<string>;

    ViewBag.HasLives = true;
    ViewBag.Lives = lives;

    string pairsJson = type == "Matching" && ViewBag.Pairs != null
    ? System.Text.Json.JsonSerializer.Serialize<object>(ViewBag.Pairs)
    : "null";


}

<div class="card">

    @* 🟦 IMAGE QUIZ (steps 1–2) *@
    @if (type == "Quiz")
    {
        <h2 class="quiz-title">@Model.EnglishText</h2>

        @if (!string.IsNullOrEmpty(Model.ImageUrl))
        {
            <img src="@Model.ImageUrl" class="image" />
        }

        @foreach (var c in choices)
        {
            <button class="choice" onclick="submitAnswer('@c')">@c</button>
        }
    }

    @* 🟨 COLOR MIXING (steps 3–4) *@
    @if (type == "Mixing")
    {
        <h2 class="quiz-title">@ViewBag.Question</h2>

        @foreach (var c in choices)
        {
            <button class="choice" onclick="submitAnswer('@c')">@c</button>
        }
    }

    @* 🟩 CONTEXT IMAGE QUESTIONS (steps 5–9) *@
    @if (type == "Context")
    {
        <div class="context-image-wrapper">
            <img src="@ViewBag.ContextImage"
                 alt="Context image" />
        </div>


        <p class="sentence">@ViewBag.ContextText</p>

        <div class="answer-row">
            <input id="fillInput"
                   class="color-input"
                   placeholder="Enter the word in Maltese" />

            <button class="color-submit"
                    onclick="submitAnswer(document.getElementById('fillInput').value)">
                Check
            </button>
        </div>
    }

    @* 🟥 MATCHING (Question 10) *@
    @if (type == "Matching")
    {
        <h3 class="sentence">Match the Maltese colors to their meanings</h3>

        <div class="matching-container">
            <div class="matching-column">
                @foreach (var m in (List<string>)ViewBag.Maltese)
                {
                    <div class="match-item maltese" data-value="@m">@m</div>
                }
            </div>

            <div class="matching-column">
                @foreach (var e in (List<string>)ViewBag.English)
                {
                    <div class="match-item english" data-value="@e">@e</div>
                }
            </div>
        </div>

        <button class="color-submit" onclick="finishMatching()">Submit</button>
    }
    <script>

        const questionType = "@type";

        function normalize(text) {
            return text
                .toLowerCase()
                .normalize("NFD")
                .replace(/[\u0300-\u036f]/g, "")
                .trim();
        }

        // ===============================
        // ✅ BUILD VALID ANSWERS ARRAY
        // ===============================
        const correctAnswers = @Html.Raw(
            System.Text.Json.JsonSerializer.Serialize(
                ViewBag.CorrectAnswer is IEnumerable<string>
                    ? ViewBag.CorrectAnswer
                    : ViewBag.CorrectAnswer != null
                        ? new List<string> { ViewBag.CorrectAnswer }
                        : !string.IsNullOrWhiteSpace(Model.MalteseWord_Font)
              ? new List<string> { Model.MalteseWord_Font, Model.MalteseText }
              : new List<string> { Model.MalteseText }
            )
        );

        // ===============================
        // ✅ NORMAL QUESTIONS (Quiz, Mixing, Context)
        // ===============================
        function submitAnswer(answer) {

            let step = @step;
            let score = @score;
            let mode = @mode;
            let lives = @lives;
            let playerCode = "@playerCode";
            let learningItemId = @Model.LearningItemId;

            if (!answer || answer.trim() === "") {
                Swal.fire("Enter an answer first!");
                return;
            }

            const normalizedInput = normalize(answer);

            const isCorrect = correctAnswers.some(a =>
                normalize(a) === normalizedInput
            );

            // ✅ CORRECT
            if (isCorrect) {

                score++;

                if (mode === 1) {
                    fetch(`/api/playerapi/addxp?playerCode=${playerCode}&amount=20`, {
                        method: "POST"
                    });
                }

                Swal.fire({
                    title: "Correct!",
                    text: mode === 1 ? "+20 XP" : "Good job!",
                    icon: "success",
                    timer: 900,
                    showConfirmButton: false
                }).then(() => {

                    window.location.href =
                        `/Color/SubmitAnswer?playerCode=${playerCode}` +
                        `&step=${step}` +
                        `&score=${score}` +
                        `&mode=${mode}` +
                        `&lives=${lives}` +
                        `&learningItemId=${learningItemId}` +
                        `&isCorrect=true`;
                });

                return;
            }

            // ❌ WRONG
            if (mode === 1) {

                lives--;

                if (lives <= 0) {
                    window.location.href =
                        `/Color/Completed?playerCode=${playerCode}&mode=${mode}&failed=true`;
                    return;
                }

                Swal.fire({
                    title: "Wrong!",
                    text: `Lives left: ${lives}`,
                    icon: "error",
                    timer: 900,
                    showConfirmButton: false
                }).then(() => {

                    window.location.href =
                        `/Color/SubmitAnswer?playerCode=${playerCode}` +
                        `&step=${step}` +
                        `&score=${score}` +
                        `&mode=${mode}` +
                        `&lives=${lives}` +
                        `&learningItemId=${learningItemId}` +
                        `&isCorrect=false`;
                });

            } else {

                Swal.fire({
                    title: "Try again!",
                    icon: "error",
                    timer: 700,
                    showConfirmButton: false
                });
            }
        }

        // ===============================
        // ✅ MATCHING LOGIC
        // ===============================
        if (questionType === "Matching") {

            const correctPairs = @Html.Raw(
                System.Text.Json.JsonSerializer.Serialize<object>(ViewBag.Pairs)
            );

            let selectedMaltese = null;
            let matchedCount = 0;

            document.querySelectorAll(".match-item.maltese").forEach(item => {
                item.addEventListener("click", () => {

                    if (item.classList.contains("matched")) return;

                    document.querySelectorAll(".match-item.maltese")
                        .forEach(i => i.classList.remove("selected"));

                    item.classList.add("selected");
                    selectedMaltese = item;
                });
            });

            document.querySelectorAll(".match-item.english").forEach(item => {
                item.addEventListener("click", () => {

                    if (!selectedMaltese || item.classList.contains("matched")) return;

                    const maltese = normalize(selectedMaltese.dataset.value);
                    const english = normalize(item.dataset.value);

                    const isCorrect = correctPairs.some(p =>
                        normalize(p.Maltese) === maltese &&
                        normalize(p.English) === english
                    );

                    if (isCorrect) {

                        selectedMaltese.classList.remove("wrong", "selected");
                        item.classList.remove("wrong");

                        selectedMaltese.classList.add("matched");
                        item.classList.add("matched");

                        matchedCount++;

                    } else {

                        selectedMaltese.classList.add("wrong");
                        item.classList.add("wrong");

                        setTimeout(() => {
                            selectedMaltese.classList.remove("wrong", "selected");
                            item.classList.remove("wrong");
                        }, 400);
                    }

                    selectedMaltese = null;
                });
            });

            window.finishMatching = function () {

                if (matchedCount < correctPairs.length) {
                    Swal.fire("Finish all matches first!");
                    return;
                }

                if (@mode === 1) {
                    fetch(`/api/playerapi/addxp?playerCode=@playerCode&amount=40`, {
                        method: "POST"
                    });
                }

                Swal.fire({
                    title: "Excellent!",
                    text: @mode === 1 ? "+40 XP" : "Well done!",
                    icon: "success",
                    timer: 1000,
                    showConfirmButton: false
                }).then(() => {

                    window.location.href =
                        `/Color/SubmitAnswer?playerCode=@playerCode` +
                        `&step=@step` +
                        `&score=@score` +
                        `&mode=@mode` +
                        `&lives=@lives` +
                        `&learningItemId=@Model.LearningItemId` +
                        `&isCorrect=true`;
                });
            };
        }

    </script>
