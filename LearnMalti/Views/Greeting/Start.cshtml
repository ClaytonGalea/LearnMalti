@model LearnMalti.Models.LearningItem

@{
    Layout = "~/Views/Shared/_GreetingLayout.cshtml";

    string playerCode = ViewBag.PlayerCode;
    int step = ViewBag.Step;
    int mode = ViewBag.Mode;
    int lives = ViewBag.Lives ?? 3;

    string type = ViewBag.QuestionType;

    var choices = ViewBag.Choices as List<LearnMalti.Models.LearningItem>
              ?? new List<LearnMalti.Models.LearningItem>();

    var malteseWords = ViewBag.Maltese as List<string> ?? new List<string>();
    var englishWords = ViewBag.English as List<string> ?? new List<string>();

    ViewBag.HasLives = true;
    ViewBag.Lives = lives;
}

<div class="card">

    @* 🟦 QUIZ *@
    @if (type == "Quiz")
    {
        <h2 class="quiz-title">@Model.EnglishText</h2>

        @foreach (var c in choices)
        {
            <div class="choice-row">

                <button class="choice"
                        onclick="submitAnswer('@c.MalteseText')">
                    @c.DisplayMalteseWord
                </button>

                <button class="audio-btn"
                        type="button"
                        onclick="playAudio('@c.AudioPath')">
                    🔊
                </button>

            </div>
        }
    }

    @* 🟨 SENTENCE *@
    @if (type == "Sentence")
    {
        <p class="english-sentence">@ViewBag.EnglishSentence</p>

        <h3 class="sentence">@ViewBag.Sentence</h3>

        @foreach (var c in choices)
        {
            <div class="choice-row">

                <button class="choice"
                        onclick="submitAnswer('@c.MalteseText')">
                    @c.DisplayMalteseWord
                </button>

                <button class="audio-btn"
                        type="button"
                        onclick="playAudio('@c.AudioPath')">
                    🔊
                </button>

            </div>
        }
    }

    @* 🟥 MATCHING *@
    @if (type == "Matching")
    {
        <h3 class="sentence">Match the Maltese words to their meanings</h3>

        <div class="matching-container">

            <div class="matching-column">
                @foreach (var m in malteseWords)
                {
                    <div class="match-item maltese"
                         data-value="@m">
                        @m
                    </div>
                }
            </div>

            <div class="matching-column">
                @foreach (var e in englishWords)
                {
                    <div class="match-item english"
                         data-value="@e">
                        @e
                    </div>
                }
            </div>

        </div>

        <button class="submit" onclick="finishMatching()">
            Submit
        </button>
    }

</div>

<script>

    /* ===== GLOBAL VARIABLES (same as other levels) ===== */

    const playerCode = "@playerCode";
    const step = @step;
    const mode = @mode;
    let lives = @lives;
    const learningItemId = @Model.LearningItemId;
    const questionType = "@type";


    function normalizeText(text) {
        return text
            .toLowerCase()
            .normalize("NFD")
            .replace(/[\u0300-\u036f]/g, "")
            .trim();
    }


    /* ===== SUBMIT ANSWER ===== */

    function submitAnswer(answer) {

        const correct = @Html.Raw(
            System.Text.Json.JsonSerializer.Serialize(
                ViewBag.CorrectAnswer ?? Model.MalteseText
            )
        );

        if (normalizeText(answer) === normalizeText(correct)) {

            if (mode === 1) {
                fetch(`/api/playerapi/addxp?playerCode=${playerCode}&amount=20`, {
                    method: "POST"
                });
            }

            Swal.fire({
                title: mode === 1 ? "Correct!" : "",
                text: mode === 1 ? "+20 XP Good job!" : "",
                icon: "success",
                timer: 900,
                showConfirmButton: false
            }).then(() => {

                window.location.href =
                    `/Greeting/SubmitAnswer?playerCode=${playerCode}` +
                    `&step=${step}` +
                    `&mode=${mode}` +
                    `&lives=${lives}` +
                    `&learningItemId=${learningItemId}` +
                    `&isCorrect=true`;
            });

            return;
        }


        if (mode === 1) {

            lives--;

            if (lives <= 0) {

                window.location.href =
                    `/Greeting/Completed?playerCode=${playerCode}` +
                    `&mode=${mode}&failed=true`;

                return;
            }

            Swal.fire({
                title: "Wrong!",
                text: `Lives left: ${lives}`,
                icon: "error",
                timer: 900,
                showConfirmButton: false
            }).then(() => {

                window.location.href =
                    `/Greeting/SubmitAnswer?playerCode=${playerCode}` +
                    `&step=${step}` +
                    `&mode=${mode}` +
                    `&lives=${lives}` +
                    `&learningItemId=${learningItemId}` +
                    `&isCorrect=false`;
            });

        }
    }
    

    /* ===== MATCHING GAME ===== */

    if (questionType === "Matching") {

        const correctPairs = @Html.Raw(
            System.Text.Json.JsonSerializer.Serialize<object>(ViewBag.Pairs)
        );

        let selectedMaltese = null;
        let matchedCount = 0;


        document.querySelectorAll(".match-item.maltese").forEach(item => {

            item.addEventListener("click", () => {

                if (item.classList.contains("matched")) return;

                document.querySelectorAll(".match-item.maltese")
                    .forEach(i => i.classList.remove("selected"));

                item.classList.add("selected");
                selectedMaltese = item;

            });

        });


        document.querySelectorAll(".match-item.english").forEach(item => {

            item.addEventListener("click", () => {

                if (!selectedMaltese || item.classList.contains("matched"))
                    return;

                const maltese = normalizeText(selectedMaltese.dataset.value);
                const english = normalizeText(item.dataset.value);

                const isCorrect = correctPairs.some(p =>
                    normalizeText(p.Maltese) === maltese &&
                    normalizeText(p.English) === english
                );


                if (isCorrect) {

                    selectedMaltese.classList.remove("wrong", "selected");
                    item.classList.remove("wrong");

                    selectedMaltese.classList.add("matched");
                    item.classList.add("matched");

                    matchedCount++;

                }
                else {

                    selectedMaltese.classList.add("wrong");
                    item.classList.add("wrong");

                    setTimeout(() => {
                        selectedMaltese.classList.remove("wrong", "selected");
                        item.classList.remove("wrong");
                    }, 400);

                }

                selectedMaltese.classList.remove("selected");
                selectedMaltese = null;

            });

        });


        window.finishMatching = function () {

            if (matchedCount < correctPairs.length) {
                Swal.fire("Finish all matches first!");
                return;
            }

            if (mode === 1) {
                fetch(`/api/playerapi/addxp?playerCode=${playerCode}&amount=40`, {
                    method: "POST"
                });
            }

            Swal.fire({
                title: "Excellent!",
                text: mode === 1 ? "+40 XP Well done!" : "",
                icon: "success",
                timer: 1000,
                showConfirmButton: false
            }).then(() => {

                window.location.href =
                    `/Greeting/SubmitAnswer?playerCode=${playerCode}` +
                    `&step=${step}` +
                    `&mode=${mode}` +
                    `&lives=${lives}` +
                    `&learningItemId=${learningItemId}` +
                    `&isCorrect=true`;
            });

        };

    }


    function playAudio(path) {

        if (!path) return;

        const audio = new Audio(path);
        audio.play();

    }

</script>