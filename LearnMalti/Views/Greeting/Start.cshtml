@model LearnMalti.Models.LearningItem

@{
    Layout = "~/Views/Shared/_GreetingLayout.cshtml";

    string playerCode = ViewBag.PlayerCode;
    int step = ViewBag.Step;
    int score = ViewBag.Score;
    int mode = ViewBag.Mode;
    int lives = ViewBag.Lives ?? 3;

    string type = ViewBag.QuestionType;
    var choices = ViewBag.Choices as List<LearnMalti.Models.LearningItem>
              ?? new List<LearnMalti.Models.LearningItem>();

    ViewBag.HasLives = true;
    ViewBag.Lives = lives;

    string pairsJson = type == "Matching" && ViewBag.Pairs != null
        ? System.Text.Json.JsonSerializer.Serialize((IEnumerable<object>)ViewBag.Pairs)
        : "null";
}

<div class="card">

    @* 🟦 QUIZ *@
    @if (type == "Quiz")
    {
        <h2 class="quiz-title">@Model.EnglishText</h2>
        @foreach (var c in choices)
        {
            <div class="choice-row">
                <button class="choice" onclick="submitAnswer('@c.MalteseText')">
                    @c.DisplayMalteseWord
                </button>

                <button class="audio-btn"
                        type="button"
                        onclick="playAudio('@c.AudioPath')">
                    🔊
                </button>
            </div>
        }
    }

    @* 🟨 SENTENCE *@
    @if (type == "Sentence")
    {
        <p class="english-sentence">@ViewBag.EnglishSentence</p>
        <h3 class="sentence">@ViewBag.Sentence</h3>
        @foreach (var c in choices)
        {
            <div class="choice-row">
                <button class="choice" onclick="submitAnswer('@c.MalteseText')">@c.DisplayMalteseWord</button>
                <button class="audio-btn"
                        type="button"
                        onclick="playAudio('@c.AudioPath')">
                    🔊
                </button>
            </div>
        }
    }


    @* 🟥 MATCHING *@
    @if (type == "Matching")
    {
        <h3 class="sentence">Match the Maltese words to their meanings</h3>

        <div class="matching-container">
            <div class="matching-column">
                @foreach (var m in (List<string>)ViewBag.Maltese)
                {
                    <div class="match-item maltese" data-value="@m">@m</div>
                }
            </div>

            <div class="matching-column">
                @foreach (var e in (List<string>)ViewBag.English)
                {
                    <div class="match-item english" data-value="@e">@e</div>
                }
            </div>
        </div>

        <button class="submit" onclick="finishMatching()">Submit</button>
    }

</div>

<script>
    /* ===== GLOBAL GAME STATE ===== */
    const gameState = {
        mode: @mode,
        playerCode: "@playerCode",
        step: @step,
        score: @score,
        lives: @lives,
        learningItemId: @Model.LearningItemId
    };

    const questionType = "@type";

    function normalizeText(text) {
        return text
            .toLowerCase()
            .normalize("NFD")
            .replace(/[\u0300-\u036f]/g, "")
            .trim();
    }

    /* ===== SUBMIT ANSWER ===== */
    function submitAnswer(answer) {

        const correct = @Html.Raw(
            System.Text.Json.JsonSerializer.Serialize(
                ViewBag.CorrectAnswer ?? Model.MalteseText
            )
        );

        let newScore = gameState.score;
        let newLives = gameState.lives;

        if (normalizeText(answer) === normalizeText(correct)) {

            newScore++;

            if (gameState.mode === 1) {
                fetch(`/api/playerapi/addxp?playerCode=${gameState.playerCode}&amount=20`, {
                    method: "POST"
                });
            }

            Swal.fire({
                title: gameState.mode === 1 ? "Correct!" : "",
                text: gameState.mode === 1 ? "+20 XP Good job!" : "",
                icon: "success",
                timer: 900,
                showConfirmButton: false
            }).then(() => {

                window.location.href =
                    `/Greeting/SubmitAnswer?playerCode=${gameState.playerCode}` +
                    `&step=${gameState.step}` +
                    `&score=${newScore}` +
                    `&mode=${gameState.mode}` +
                    `&lives=${newLives}` +
                    `&learningItemId=${gameState.learningItemId}` +
                    `&isCorrect=true`;
            });

            return;
        }

        if (gameState.mode === 1) {

            newLives--;

            if (newLives <= 0) {
                window.location.href =
                    `/Greeting/Completed?playerCode=${gameState.playerCode}&mode=${gameState.mode}&failed=true`;
                return;
            }

            Swal.fire({
                title: "Wrong!",
                text: `Lives left: ${newLives}`,
                icon: "error",
                timer: 900,
                showConfirmButton: false
            }).then(() => {

                window.location.href =
                    `/Greeting/SubmitAnswer?playerCode=${gameState.playerCode}` +
                    `&step=${gameState.step}` +
                    `&score=${newScore}` +
                    `&mode=${gameState.mode}` +
                    `&lives=${newLives}` +
                    `&learningItemId=${gameState.learningItemId}` +
                    `&isCorrect=false`;
            });
        }
    }

    /* ===== MATCHING ===== */
    if (questionType === "Matching") {

        const correctPairs = @Html.Raw(
            System.Text.Json.JsonSerializer.Serialize<object>(ViewBag.Pairs)
        );

        let selectedMaltese = null;
        let matchedCount = 0;

        document.querySelectorAll(".match-item.maltese").forEach(item => {
            item.addEventListener("click", () => {

                if (item.classList.contains("matched")) return;

                document.querySelectorAll(".match-item.maltese")
                    .forEach(i => i.classList.remove("selected"));

                item.classList.add("selected");
                selectedMaltese = item;
            });
        });

        document.querySelectorAll(".match-item.english").forEach(item => {
            item.addEventListener("click", () => {

                if (!selectedMaltese || item.classList.contains("matched")) return;

                const maltese = normalizeText(selectedMaltese.dataset.value);
                const english = normalizeText(item.dataset.value);

                const isCorrect = correctPairs.some(p =>
                    normalizeText(p.Maltese) === maltese &&
                    normalizeText(p.English) === english
                );

                if (isCorrect) {

                    selectedMaltese.classList.remove("wrong", "selected");
                    item.classList.remove("wrong");

                    selectedMaltese.classList.add("matched");
                    item.classList.add("matched");

                    matchedCount++;

                } else {

                    selectedMaltese.classList.add("wrong");
                    item.classList.add("wrong");

                    setTimeout(() => {
                        selectedMaltese.classList.remove("wrong", "selected");
                        item.classList.remove("wrong");
                    }, 400);
                }

                selectedMaltese.classList.remove("selected");
                selectedMaltese = null;
            });
        });

        window.finishMatching = function () {

            if (matchedCount < correctPairs.length) {
                Swal.fire("Finish all matches first!");
                return;
            }

            if (gameState.mode === 1) {
                fetch(`/api/playerapi/addxp?playerCode=${gameState.playerCode}&amount=40`, {
                    method: "POST"
                });
            }

            Swal.fire({
                title: "Excellent!",
                text: gameState.mode === 1 ? "+40 XP Well done!" : "",
                icon: "success",
                timer: 1000,
                showConfirmButton: false
            }).then(() => {

                window.location.href =
                    `/Greeting/SubmitAnswer?playerCode=${gameState.playerCode}` +
                    `&step=${gameState.step}` +
                    `&score=${gameState.score}` +
                    `&mode=${gameState.mode}` +
                    `&lives=${gameState.lives}` +
                    `&learningItemId=${gameState.learningItemId}` +
                    `&isCorrect=true`;
            });
        };
    }

    function playAudio(path) {
        if (!path) return;
        const audio = new Audio(path);
        audio.play();
    }
</script>
