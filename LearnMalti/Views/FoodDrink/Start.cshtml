@model LearnMalti.Models.LearningItem

@{
    Layout = "~/Views/Shared/_FoodDrinkLayout.cshtml";

    string playerCode = ViewBag.PlayerCode;
    int step = ViewBag.Step;
    int score = ViewBag.Score;
    int mode = ViewBag.Mode;
    string type = ViewBag.QuestionType;
    var choices = ViewBag.Choices as List<string>;
    string sentence = ViewBag.Sentence;
    int lives = ViewBag.Lives ?? 3;
    ViewBag.HasLives = true;
    ViewBag.Lives = lives;
}

<div class="card">

    @if (type == "Quiz")
    {
        <h2 class="quiz-title">@Model.EnglishText</h2>

        @if (!string.IsNullOrEmpty(Model.ImageUrl))
        {
            <img src="@Model.ImageUrl"
            class="image quiz-image"
            alt="@Model.EnglishText" />
        }

        @foreach (var c in choices)
        {
            <button class="choice" onclick="submitAnswer('@c')">@c</button>
        }
    }


    @if (type == "ImageInput")
    {
        <img src="@Model.ImageUrl" class="image" />

        <div class="answer-row">
            <input id="fillInput"
            class="input"
            placeholder="Ikteb il-kelma bil-Malti" />

            <button class="submit"
            onclick="submitAnswer(document.getElementById('fillInput').value)">
                Submit
            </button>

       
            <button class="hint-btn" onclick="showHint()">
                    💡 Hint
            </button>
            
        </div>

        <p id="hintText" class="hint-text"></p>
    }

    @if (type == "Sentence")
    {
        <p class="english-sentence">@ViewBag.EnglishSentence</p>

        <h3 class="sentence">@sentence</h3>

        @foreach (var c in choices)
        {
            <button class="choice" onclick="submitAnswer('@c')">@c</button>
        }
    }


</div>

<script>
    function normalize(text) {
        return text
            .toLowerCase()
            .normalize("NFD")
            .replace(/[\u0300-\u036f]/g, "");
    }

     // ✅ BUILD VALID ANSWERS ARRAY FROM MODEL
    const correctAnswers = @Html.Raw(
           System.Text.Json.JsonSerializer.Serialize(
               ViewBag.CorrectAnswer != null
                   ? new List<string> { ViewBag.CorrectAnswer }
                   : !string.IsNullOrWhiteSpace(Model.MalteseWord_Font)
         ? new List<string> { Model.MalteseWord_Font, Model.MalteseText }
         : new List<string> { Model.MalteseText }
           )
       );

        function submitAnswer(answer) {

        let step = @step;
        let score = @score;
        let mode = @mode;
        let lives = @lives;
        let playerCode = "@playerCode";
        let learningItemId = @Model.LearningItemId;

        const normalizedInput = normalize(answer.trim());

           const isCorrect = correctAnswers.some(a =>
               normalize(a) === normalizedInput
           );

        // ✅ CORRECT
        if (isCorrect) {

            score++;

            if (mode === 1) {
                fetch(`/api/playerapi/addxp?playerCode=${playerCode}&amount=20`, {
                    method: "POST"
                });
            }

            Swal.fire({
                title: "Correct!",
                text: mode === 1 ? "+20 XP" : "Good job!",
                icon: "success",
                timer: 900,
                showConfirmButton: false
            }).then(() => {

                window.location.href =
                    `/FoodDrink/SubmitAnswer?playerCode=${playerCode}` +
                    `&step=${step}` +
                    `&score=${score}` +
                    `&mode=${mode}` +
                    `&lives=${lives}` +
                    `&learningItemId=${learningItemId}` +
                    `&isCorrect=true`;
            });

            return;
        }

        // ❌ WRONG
        if (mode === 1) {

            lives--;

            if (lives <= 0) {
                window.location.href =
                    `/FoodDrink/Completed?playerCode=${playerCode}&mode=${mode}&failed=true`;
                return;
            }

            Swal.fire({
                title: "Wrong!",
                text: `Lives left: ${lives}`,
                icon: "error",
                timer: 900,
                showConfirmButton: false
            }).then(() => {

                window.location.href =
                    `/FoodDrink/SubmitAnswer?playerCode=${playerCode}` +
                    `&step=${step}` +
                    `&score=${score}` +
                    `&mode=${mode}` +
                    `&lives=${lives}` +
                    `&learningItemId=${learningItemId}` +
                    `&isCorrect=false`;
            });

        } else {

            Swal.fire({
                title: "Try again!",
                icon: "error",
                timer: 800,
                showConfirmButton: false
            });
        }
    }
    

    function showHint() {
        const correct = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
            ViewBag.CorrectAnswer ?? Model.DisplayMalteseWord
        ));

        if (!correct || correct.length < 3) return;                                                                                                                                                                                         

        const firstTwo = correct.substring(0, 2);
        const lastLetter = correct.substring(correct.length - 1);

        let middle = "";
        for (let i = 0; i < correct.length - 3; i++) {
            middle += "_ ";
        }

        document.getElementById("hintText").innerText =
            `Hint: ${firstTwo} ${middle}${lastLetter}`;
    }

</script>